              "    \r",
              "    // Extract token from your custom response format: response.data.token\r",
              "    if (responseJson.data && responseJson.data.token) {\r",
              "        pm.collectionVariables.set(\"token\", responseJson.data.token);\r",
              "        console.log(\"Token successfully saved: \" + responseJson.data.token);\r",
              "    }\r",
              "}\r",
